# Dockerfile used by docker-compose.api-test.yml only.
# Skips the apk add step so it works in air-gapped / restricted environments.
# Uses golang:1.25-alpine as both builder and final stage (provides BusyBox
# wget for the healthcheck without needing network package installation).

FROM golang:1.25-alpine AS builder
WORKDIR /build
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build \
    -ldflags="-s -w -extldflags '-static'" \
    -a -installsuffix cgo \
    -o bin/server \
    ./cmd/server

FROM golang:1.25-alpine
WORKDIR /app
COPY --from=builder /build/bin/server /app/server
COPY --from=builder /build/configs /app/configs
COPY --from=builder /build/migrations /app/migrations
EXPOSE 8080
HEALTHCHECK --interval=5s --timeout=3s --start-period=10s --retries=12 \
    CMD wget -q --spider http://localhost:8080/health || exit 1
ENTRYPOINT ["/app/server"]
